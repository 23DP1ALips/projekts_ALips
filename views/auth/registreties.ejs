<%- include('../partials/header') %>

<form action="/registreties" method="post" class="forma" novalidate>
    <h1><%= t('auth.register_title') %></h1>
    <p class="palidzigais"><%= t('auth.register_lead') %></p>

    <% if (kludas.visparigs) { %>
        <div class="zinojums kluda" role="alert"><%= t(kludas.visparigs) %></div>
    <% } %>

    <div class="lauks">
        <label for="lietotajvards"><%= t('auth.username') %></label>
        <input id="lietotajvards" name="lietotajvards" type="text" required minlength="3" maxlength="50" autocomplete="username" value="<%= forma.lietotajvards %>" aria-describedby="palidzigais-lietotajvards">
        <span id="palidzigais-lietotajvards" class="palidzigais"><%= t('auth.username_help') %></span>
        <% if (kludas.lietotajvards) { %><span class="lauka-kluda"><%= t(kludas.lietotajvards) %></span><% } %>
    </div>

    <div class="lauks">
        <label for="epasts"><%= t('auth.email') %></label>
        <input id="epasts" name="epasts" type="email" required maxlength="100" autocomplete="email" value="<%= forma.epasts %>">
        <% if (kludas.epasts) { %><span class="lauka-kluda"><%= t(kludas.epasts) %></span><% } %>
    </div>

    <div class="lauks">
        <label for="parole"><%= t('auth.password') %></label>
        <input id="parole" name="parole" type="password" required minlength="8" maxlength="100" autocomplete="new-password" aria-describedby="palidzigais-parole">
        <span id="palidzigais-parole" class="palidzigais"><%= t('auth.password_help') %></span>
        <% if (kludas.parole) { %><span class="lauka-kluda"><%= t(kludas.parole) %></span><% } %>
    </div>

    <div class="lauks">
        <label for="paroleApstiprinata"><%= t('auth.password_repeat') %></label>
        <input id="paroleApstiprinata" name="paroleApstiprinata" type="password" required minlength="8" maxlength="100" autocomplete="new-password">
        <% if (kludas.paroleApstiprinata) { %><span class="lauka-kluda"><%= t(kludas.paroleApstiprinata) %></span><% } %>
    </div>

    <div class="formas-darbibas">
        <button type="submit" class="poga primara"><%= t('auth.create_account') %></button>
        <a href="/pieslegties" class="poga saite"><%= t('auth.have_account') %></a>
    </div>
</form>

<%- include('../partials/footer') %>
