PORT=3000

# Bazes URL paroles atjaunosanas saitēm. Atstajiet tuksu lokāli (auto-detekcija).
# Production: BASE_URL=https://forums.example.com
BASE_URL=

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=forums

SESSION_SECRET=mainit-uz-savu-noslepumu

# AI asistents (neobligats - ja tukss, asistents stradas lokala fallback rezima)
# Dabu atslegu: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Atbalsta epasta sistema
# Ja SMTP_HOST tukss, vesteles tiek izvaditas konsolē (dev rezims).
SUPPORT_EMAIL=support@yourdomain.lv
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Forums <noreply@yourdomain.lv>
