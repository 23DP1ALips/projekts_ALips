<%- include('../partials/header') %>
<%- include('partials/admin-nav') %>

<div class="lapas-virsraksts">
    <h1><%= t('admin_atbalsts.request_from', { user: pieprasijums.nosutitaja_vards }) %></h1>
    <a href="/admin/atbalsts" class="poga"><%= t('admin_atbalsts.back') %></a>
</div>

<article class="ieraksta-saturs">
    <p class="ieraksta-meta">
        <%= format.formatDatums(pieprasijums.izveidots) %> ·
        <%= pieprasijums.nosutitaja_epasts %> ·
        <% if (pieprasijums.lietotajvards) { %>
            <a href="/lietotaji/<%= pieprasijums.lietotajs_id %>"><%= pieprasijums.lietotajvards %></a>
        <% } else { %>
            <span class="palidzigais"><%= t('admin_atbalsts.no_account') %></span>
        <% } %>
        ·
        <span class="marka <%= pieprasijums.statuss === 'atbildets' ? 'aktivs' : (pieprasijums.statuss === 'aizverts' ? 'blokets' : '') %>"><%= t('atbalsts.status_' + pieprasijums.statuss) %></span>
    </p>
    <h2><%= pieprasijums.tema %></h2>
    <div><%- format.nl2br(pieprasijums.zinojums) %></div>
</article>

<form action="/admin/atbalsts/<%= pieprasijums.atbalsts_id %>/atbilde" method="post" class="forma plata" novalidate>
    <h2><%= t('admin_atbalsts.reply_label') %></h2>
    <p class="palidzigais"><%= t('admin_atbalsts.reply_help') %></p>
    <div class="lauks">
        <textarea id="atbilde" name="atbilde" required minlength="5" maxlength="5000" rows="8"><%= forma.atbilde %></textarea>
        <% if (kludas.atbilde) { %><span class="lauka-kluda"><%= t(kludas.atbilde) %></span><% } %>
    </div>
    <div class="formas-darbibas">
        <button type="submit" class="poga primara"><%= t('admin_atbalsts.send_reply') %></button>
        <% if (pieprasijums.statuss !== 'aizverts') { %>
            <form action="/admin/atbalsts/<%= pieprasijums.atbalsts_id %>/aizvert" method="post" class="iekslinis" data-apstiprinat="<%= t('admin_atbalsts.close_confirm') %>">
                <button type="submit" class="poga"><%= t('admin_atbalsts.close') %></button>
            </form>
        <% } %>
    </div>
</form>

<% if (pieprasijums.atbilde) { %>
    <article class="ieraksta-saturs" style="margin-top: 16px;">
        <h3><%= t('atbalsts.reply_from', { user: pieprasijums.atbildejusais || '—' }) %></h3>
        <p class="ieraksta-meta"><%= format.formatDatums(pieprasijums.atbildets) %></p>
        <div><%- format.nl2br(pieprasijums.atbilde) %></div>
    </article>
<% } %>

<%- include('../partials/footer') %>
